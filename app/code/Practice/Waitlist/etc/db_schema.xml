<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="practice_waitlist" resource="default" engine="innodb" comment="Waitlist Table">
        <!-- columns go here -->
        <column xsi:type="int" name="entity_id" unsigned="true" nullable="false" identity="true" comment="Entity ID"/>
        <column xsi:type="int" name="product_id" unsigned="true" nullable="false" comment="Product ID"/>
        <column xsi:type="varchar" name="customer_name" nullable="false" comment="Customer Name"/>
        <column xsi:type="varchar" name="customer_email" nullable="false" comment="Customer Email"/>
        <column xsi:type="varchar" name="customer_phone" nullable="false" comment="Customer Phone"/>
        <column xsi:type="text" name="customer_comment" nullable="false" comment="Customer Comment"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>
        
        <!-- constraints go here -->
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>

        <!-- indexes -->
        <index referenceId="PRACTICE_WAITLIST_PRODUCT_ID" indexType="btree">
            <column name="product_id"/>
        </index>
        
    </table>
</schema>